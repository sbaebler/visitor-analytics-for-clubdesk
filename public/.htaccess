# Security Headers (LiteSpeed / Apache kompatibel)
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    # CSP wird pro Seite per PHP gesetzt (verschiedene Anforderungen)
</IfModule>

# widget.php darf in iframes eingebettet werden (Social Widget für Clubdesk)
<Files "widget.php">
    <IfModule mod_headers.c>
        Header always set X-Frame-Options "ALLOWALL"
    </IfModule>
</Files>

# Defense-in-Depth: setup/ liegt normalerweise ausserhalb des Document Roots
# (public/) und ist damit gar nicht web-erreichbar. Diese Regeln blockieren es
# zusätzlich, falls der Document Root versehentlich auf das Repo-Root zeigt.
<Files "install.php">
    Order allow,deny
    Deny from all
</Files>

# Kein Zugriff auf Konfigurationsdateien
<FilesMatch "\.(php)$">
    <If "%{REQUEST_URI} =~ m#^/setup/#">
        Order allow,deny
        Deny from all
    </If>
</FilesMatch>

# Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/javascript "access plus 1 hour"
    ExpiresByType text/css              "access plus 1 hour"
</IfModule>

# Verzeichnislisting deaktivieren
Options -Indexes
